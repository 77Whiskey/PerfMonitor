<UserControl x:Class="FenixFpm.Desktop.Views.TakeoffView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             mc:Ignorable="d"
             d:DesignHeight="760"
             d:DesignWidth="1180">
    <UserControl.Resources>
        <SolidColorBrush x:Key="ViewBackgroundBrush" Color="#FF121212" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FF1E1E1E" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#FF2B2B2B" />
        <SolidColorBrush x:Key="ReadoutBrush" Color="#FF00A8FF" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#FFF5F7FA" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#FF96A0AA" />
        <SolidColorBrush x:Key="GridBrush" Color="#FF242424" />

        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="22" />
        </Style>

        <Style x:Key="PanelTitleStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Bahnschrift" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
        </Style>

        <Style x:Key="ReadoutStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Bahnschrift" />
            <Setter Property="FontSize" Value="40" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource ReadoutBrush}" />
        </Style>

        <Style x:Key="MetricLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Bahnschrift" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource ViewBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="24" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="TAKEOFF PERFORMANCE"
                       FontFamily="Bahnschrift"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="{StaticResource PrimaryTextBrush}" />
            <TextBlock Margin="0,6,0,0"
                       Text="Thrust application, rotation geometry, and pitch trace through the takeoff roll."
                       FontFamily="Bahnschrift"
                       FontSize="13"
                       Foreground="{StaticResource SecondaryTextBrush}" />
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelStyle}">
                <StackPanel>
                    <TextBlock Text="ENGINE 1 N1" Style="{StaticResource MetricLabelStyle}" />
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <TextBlock Text="{Binding ActiveFlight.Engine1N1, StringFormat={}{0:F1}}"
                                   Style="{StaticResource ReadoutStyle}" />
                        <TextBlock Margin="8,0,0,8"
                                   VerticalAlignment="Bottom"
                                   Text="%"
                                   FontFamily="Bahnschrift"
                                   FontSize="15"
                                   Foreground="{StaticResource SecondaryTextBrush}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource PanelStyle}">
                <StackPanel>
                    <TextBlock Text="ENGINE 2 N1" Style="{StaticResource MetricLabelStyle}" />
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <TextBlock Text="{Binding ActiveFlight.Engine2N1, StringFormat={}{0:F1}}"
                                   Style="{StaticResource ReadoutStyle}" />
                        <TextBlock Margin="8,0,0,8"
                                   VerticalAlignment="Bottom"
                                   Text="%"
                                   FontFamily="Bahnschrift"
                                   FontSize="15"
                                   Foreground="{StaticResource SecondaryTextBrush}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource PanelStyle}">
                <StackPanel>
                    <TextBlock Text="INDICATED AIRSPEED" Style="{StaticResource MetricLabelStyle}" />
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <TextBlock Text="{Binding ActiveFlight.IndicatedAirspeedKnots, StringFormat={}{0:F0}}"
                                   Style="{StaticResource ReadoutStyle}" />
                        <TextBlock Margin="8,0,0,8"
                                   VerticalAlignment="Bottom"
                                   Text="KT"
                                   FontFamily="Bahnschrift"
                                   FontSize="15"
                                   Foreground="{StaticResource SecondaryTextBrush}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="6" Style="{StaticResource PanelStyle}">
                <StackPanel>
                    <TextBlock Text="ROTATION RATE" Style="{StaticResource MetricLabelStyle}" />
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <TextBlock Text="{Binding ActiveFlight.RotationRateDegreesPerSecond, StringFormat={}{0:F2}}"
                                   Style="{StaticResource ReadoutStyle}" />
                        <TextBlock Margin="8,0,0,8"
                                   VerticalAlignment="Bottom"
                                   Text="DEG/S"
                                   FontFamily="Bahnschrift"
                                   FontSize="15"
                                   Foreground="{StaticResource SecondaryTextBrush}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="4" Style="{StaticResource PanelStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="260" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="ROTATION PROFILE"
                               Style="{StaticResource PanelTitleStyle}" />
                    <TextBlock Grid.Column="1"
                               FontFamily="Bahnschrift"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               Text="{Binding ActiveFlight.PitchDegrees, StringFormat={}{0:F1} DEG}" />
                </Grid>

                <Border Grid.Row="2"
                        Grid.Column="0"
                        CornerRadius="14"
                        Background="#FF171717"
                        BorderBrush="{StaticResource GridBrush}"
                        BorderThickness="1"
                        Padding="12">
                    <lvc:CartesianChart Series="{Binding PitchSeries}"
                                        XAxes="{Binding XAxes}"
                                        YAxes="{Binding YAxes}"
                                        Background="Transparent" />
                </Border>

                <Border Grid.Row="2"
                        Grid.Column="2"
                        CornerRadius="14"
                        Background="#FF171717"
                        BorderBrush="{StaticResource GridBrush}"
                        BorderThickness="1"
                        Padding="18">
                    <StackPanel>
                        <TextBlock Text="CURRENT PITCH"
                                   Style="{StaticResource MetricLabelStyle}" />
                        <TextBlock Margin="0,10,0,0"
                                   Text="{Binding ActiveFlight.PitchDegrees, StringFormat={}{0:F1}}"
                                   FontFamily="Bahnschrift"
                                   FontSize="48"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource ReadoutBrush}" />
                        <TextBlock Text="DEG"
                                   FontFamily="Bahnschrift"
                                   FontSize="14"
                                   Foreground="{StaticResource SecondaryTextBrush}" />

                        <Border Margin="0,18,0,18"
                                BorderBrush="{StaticResource GridBrush}"
                                BorderThickness="0,1,0,0" />

                        <TextBlock Text="CHART CONTEXT"
                                   Style="{StaticResource MetricLabelStyle}" />
                        <TextBlock Margin="0,10,0,0"
                                   Text="Pitch attitude is sampled once per second after the takeoff roll becomes active. The trace lets instructors see rotation onset, pitch target acquisition, and over-rotation tendencies."
                                   FontFamily="Bahnschrift"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource SecondaryTextBrush}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
