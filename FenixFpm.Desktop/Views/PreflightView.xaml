<UserControl x:Class="FenixFpm.Desktop.Views.PreflightView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="1080">
    <UserControl.Resources>
        <SolidColorBrush x:Key="ViewBackgroundBrush" Color="#FF121212" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FF1E1E1E" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#FF2B2B2B" />
        <SolidColorBrush x:Key="ReadoutBrush" Color="#FF00A8FF" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#FFF5F7FA" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#FF96A0AA" />
        <SolidColorBrush x:Key="GoodBrush" Color="#FF46D28A" />
        <SolidColorBrush x:Key="AlertBrush" Color="#FFFFB347" />

        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="22" />
            <Setter Property="Margin" Value="0,0,0,0" />
        </Style>

        <Style x:Key="PanelTitleStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Bahnschrift" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Bahnschrift" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
        </Style>

        <Style x:Key="ReadoutStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Bahnschrift" />
            <Setter Property="FontSize" Value="34" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource ReadoutBrush}" />
        </Style>

        <Style x:Key="StatusValueStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Bahnschrift" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource ViewBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="24" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="PREFLIGHT &amp; TAXI MONITOR"
                           FontFamily="Bahnschrift"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="{StaticResource PrimaryTextBrush}" />
                <TextBlock Margin="0,6,0,0"
                           Text="Environmental readiness, system availability, and ground configuration."
                           FontFamily="Bahnschrift"
                           FontSize="13"
                           Foreground="{StaticResource SecondaryTextBrush}" />
            </StackPanel>

            <Border Grid.Column="1"
                    Padding="14,10"
                    CornerRadius="14"
                    Background="#FF181818"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="PHASE"
                               Style="{StaticResource LabelStyle}"
                               HorizontalAlignment="Right" />
                    <TextBlock Text="{Binding ActiveFlight.FlightPhase}"
                               FontFamily="Bahnschrift"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{StaticResource ReadoutBrush}"
                               HorizontalAlignment="Right" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="20" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Row="0"
                    Grid.Column="0"
                    Style="{StaticResource PanelStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="24" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="ENVIRONMENT"
                               Style="{StaticResource PanelTitleStyle}" />

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Padding="18"
                                CornerRadius="14"
                                Background="#FF171717"
                                BorderBrush="#FF242424"
                                BorderThickness="1">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="OUTSIDE AIR TEMP"
                                           Style="{StaticResource LabelStyle}" />
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <TextBlock Text="{Binding ActiveFlight.OutsideAirTempC, StringFormat={}{0:F1}}"
                                               Style="{StaticResource ReadoutStyle}" />
                                    <TextBlock Margin="8,0,0,6"
                                               VerticalAlignment="Bottom"
                                               Text="°C"
                                               FontFamily="Bahnschrift"
                                               FontSize="14"
                                               Foreground="{StaticResource SecondaryTextBrush}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2"
                                Padding="18"
                                CornerRadius="14"
                                Background="#FF171717"
                                BorderBrush="#FF242424"
                                BorderThickness="1">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="GROSS WEIGHT"
                                           Style="{StaticResource LabelStyle}" />
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <TextBlock Text="{Binding ActiveFlight.GrossWeightKg, StringFormat={}{0:F0}}"
                                               Style="{StaticResource ReadoutStyle}" />
                                    <TextBlock Margin="8,0,0,6"
                                               VerticalAlignment="Bottom"
                                               Text="kg"
                                               FontFamily="Bahnschrift"
                                               FontSize="14"
                                               Foreground="{StaticResource SecondaryTextBrush}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="0"
                    Grid.Column="2"
                    Style="{StaticResource PanelStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="24" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="SYSTEMS CHECK"
                               Style="{StaticResource PanelTitleStyle}" />

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Grid.Column="0"
                                Padding="16"
                                CornerRadius="14"
                                Background="#FF171717"
                                BorderBrush="#FF242424"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="APU BLEED" Style="{StaticResource LabelStyle}" />
                                <TextBlock Margin="0,10,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource StatusValueStyle}">
                                            <Setter Property="Text" Value="OFF" />
                                            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ActiveFlight.ApuBleedActive}" Value="True">
                                                    <Setter Property="Text" Value="ON" />
                                                    <Setter Property="Foreground" Value="{StaticResource GoodBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="0" Grid.Column="2"
                                Padding="16"
                                CornerRadius="14"
                                Background="#FF171717"
                                BorderBrush="#FF242424"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="ENG 1 ANTI-ICE" Style="{StaticResource LabelStyle}" />
                                <TextBlock Margin="0,10,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource StatusValueStyle}">
                                            <Setter Property="Text" Value="OFF" />
                                            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ActiveFlight.Engine1AntiIce}" Value="True">
                                                    <Setter Property="Text" Value="ON" />
                                                    <Setter Property="Foreground" Value="{StaticResource GoodBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2" Grid.Column="0"
                                Padding="16"
                                CornerRadius="14"
                                Background="#FF171717"
                                BorderBrush="#FF242424"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="ENG 2 ANTI-ICE" Style="{StaticResource LabelStyle}" />
                                <TextBlock Margin="0,10,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource StatusValueStyle}">
                                            <Setter Property="Text" Value="OFF" />
                                            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ActiveFlight.Engine2AntiIce}" Value="True">
                                                    <Setter Property="Text" Value="ON" />
                                                    <Setter Property="Foreground" Value="{StaticResource GoodBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2" Grid.Column="2"
                                Padding="16"
                                CornerRadius="14"
                                Background="#FF171717"
                                BorderBrush="#FF242424"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="WING ANTI-ICE" Style="{StaticResource LabelStyle}" />
                                <TextBlock Margin="0,10,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource StatusValueStyle}">
                                            <Setter Property="Text" Value="OFF" />
                                            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ActiveFlight.WingAntiIce}" Value="True">
                                                    <Setter Property="Text" Value="ON" />
                                                    <Setter Property="Foreground" Value="{StaticResource GoodBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Style="{StaticResource PanelStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="24" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="CONFIGURATION"
                               Style="{StaticResource PanelTitleStyle}" />

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Padding="20"
                                CornerRadius="14"
                                Background="#FF171717"
                                BorderBrush="#FF242424"
                                BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="FLAP SETTING" Style="{StaticResource LabelStyle}" />
                                <TextBlock Grid.Row="2"
                                           Text="{Binding ActiveFlight.FlapsHandleIndex, StringFormat=CONF {0:F0}}"
                                           Style="{StaticResource ReadoutStyle}" />
                            </Grid>
                        </Border>

                        <Border Grid.Column="2"
                                Padding="20"
                                CornerRadius="14"
                                Background="#FF171717"
                                BorderBrush="#FF242424"
                                BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="PARKING BRAKE" Style="{StaticResource LabelStyle}" />
                                <TextBlock Grid.Row="2"
                                           FontFamily="Bahnschrift"
                                           FontSize="34"
                                           FontWeight="Bold"
                                           Text="{Binding ActiveFlight.ParkingBrakeState}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource AlertBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ActiveFlight.ParkingBrakeState}" Value="SET">
                                                    <Setter Property="Foreground" Value="{StaticResource GoodBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
