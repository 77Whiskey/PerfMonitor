<UserControl x:Class="FenixFpm.Desktop.Views.DebriefView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:FenixFpm.Core.Models;assembly=FenixFpm.Core"
             mc:Ignorable="d"
             d:DesignHeight="760"
             d:DesignWidth="1180">
    <UserControl.Resources>
        <SolidColorBrush x:Key="ViewBackgroundBrush" Color="#FF121212" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FF1E1E1E" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#FF2B2B2B" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#FFF5F7FA" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#FF96A0AA" />
        <SolidColorBrush x:Key="GridLineBrush" Color="#FF2F2F2F" />
        <SolidColorBrush x:Key="GreenScoreBrush" Color="#FF46D28A" />
        <SolidColorBrush x:Key="YellowScoreBrush" Color="#FFFFC857" />
        <SolidColorBrush x:Key="RedScoreBrush" Color="#FFFF6B6B" />
        <SolidColorBrush x:Key="WarningBrush" Color="#FFFF6B6B" />
        <SolidColorBrush x:Key="AdvisoryBrush" Color="#FFFFC857" />
        <SolidColorBrush x:Key="InfoBrush" Color="#FF00A8FF" />

        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="22" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Bahnschrift" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
        </Style>

        <Style x:Key="MetricValueStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Bahnschrift" />
            <Setter Property="FontSize" Value="26" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource InfoBrush}" />
        </Style>

        <Style x:Key="SeverityTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="FontFamily" Value="Bahnschrift" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Severity}" Value="{x:Static models:EventSeverity.Warning}">
                    <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Severity}" Value="{x:Static models:EventSeverity.Advisory}">
                    <Setter Property="Foreground" Value="{StaticResource AdvisoryBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource ViewBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="24" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="POST-FLIGHT DEBRIEF &amp; SCORECARD"
                       FontFamily="Bahnschrift"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="{StaticResource PrimaryTextBrush}" />
            <TextBlock Margin="0,6,0,0"
                       Text="Completed-flight scoring, exceedance review, and event chronology."
                       FontFamily="Bahnschrift"
                       FontSize="13"
                       Foreground="{StaticResource SecondaryTextBrush}" />
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="24" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="THE SCORE"
                               Style="{StaticResource SectionTitleStyle}" />

                    <StackPanel Grid.Row="2">
                        <TextBlock Text="{Binding SelectedFlightLabel}"
                                   FontFamily="Bahnschrift"
                                   FontSize="14"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   TextWrapping="Wrap" />
                        <TextBlock Margin="0,14,0,0"
                                   FontFamily="Bahnschrift"
                                   FontSize="84"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Left"
                                   Text="{Binding OverallScore, StringFormat={}{0:F1}}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource RedScoreBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ScoreBand}" Value="Green">
                                            <Setter Property="Foreground" Value="{StaticResource GreenScoreBrush}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ScoreBand}" Value="Yellow">
                                            <Setter Property="Foreground" Value="{StaticResource YellowScoreBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="OVERALL PERFORMANCE SCORE"
                                   FontFamily="Bahnschrift"
                                   FontSize="12"
                                   Foreground="{StaticResource SecondaryTextBrush}" />
                    </StackPanel>

                    <Border Grid.Row="4"
                            Padding="18"
                            CornerRadius="14"
                            Background="#FF171717"
                            BorderBrush="#FF242424"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="FLIGHT DURATION"
                                           Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Margin="0,10,0,0"
                                           Style="{StaticResource MetricValueStyle}"
                                           Text="{Binding FlightDuration, StringFormat={}{0:hh\:mm\:ss}}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="TOTAL WARNINGS"
                                           Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Margin="0,10,0,0"
                                           FontFamily="Bahnschrift"
                                           FontSize="26"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource WarningBrush}"
                                           Text="{Binding TotalWarnings}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="6"
                            Padding="18"
                            CornerRadius="14"
                            Background="#FF171717"
                            BorderBrush="#FF242424"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="INTERPRETATION"
                                       Style="{StaticResource SectionTitleStyle}" />
                            <TextBlock Margin="0,10,0,0"
                                       FontFamily="Bahnschrift"
                                       FontSize="13"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="The score is derived from the persisted telemetry, exceedance history, and evaluation outputs stored for the selected session." />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="8"
                            Padding="18"
                            CornerRadius="14"
                            Background="#FF171717"
                            BorderBrush="#FF242424"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="SESSION STATE"
                                       Style="{StaticResource SectionTitleStyle}" />
                            <TextBlock Margin="0,10,0,0"
                                       FontFamily="Bahnschrift"
                                       FontSize="14"
                                       Foreground="{StaticResource PrimaryTextBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="No completed session selected." />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasSession}" Value="True">
                                                <Setter Property="Text" Value="Debrief loaded from persisted session data." />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource PanelStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="EXCEEDANCE LOG"
                               Style="{StaticResource SectionTitleStyle}" />

                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding ExceedancesLog}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserResizeRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              BorderThickness="0"
                              RowHeaderWidth="0"
                              Background="#FF1E1E1E"
                              Foreground="White"
                              RowBackground="#FF1E1E1E"
                              AlternatingRowBackground="#FF2A2A2A"
                              HorizontalGridLinesBrush="{StaticResource GridLineBrush}"
                              VerticalGridLinesBrush="{StaticResource GridLineBrush}">
                        <DataGrid.Resources>
                            <Style TargetType="DataGrid">
                                <Setter Property="FontFamily" Value="Bahnschrift" />
                                <Setter Property="FontSize" Value="12" />
                            </Style>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#FF181818" />
                                <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
                                <Setter Property="FontFamily" Value="Bahnschrift" />
                                <Setter Property="FontSize" Value="11" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter Property="BorderBrush" Value="{StaticResource GridLineBrush}" />
                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                                <Setter Property="Padding" Value="10,8" />
                            </Style>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Padding" Value="0" />
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#FF252525" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Padding" Value="10,8" />
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="TIME"
                                                Binding="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}"
                                                Width="90" />
                            <DataGridTextColumn Header="PHASE"
                                                Binding="{Binding FlightPhase}"
                                                Width="120" />
                            <DataGridTemplateColumn Header="SEVERITY"
                                                    Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Severity}"
                                                   Style="{StaticResource SeverityTextStyle}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="DESCRIPTION"
                                                Binding="{Binding Description}"
                                                Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
